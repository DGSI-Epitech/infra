{
  "name": "infra",
  "private": true,
  "scripts": {
    "setup": "node scripts/install-terraform.js",

    "tf:fmt": "terraform fmt -recursive terraform",

    "tf:validate:onprem": "terraform -chdir=terraform/envs/onprem validate",
    "tf:validate:remote": "terraform -chdir=terraform/envs/remote validate",

    "tf:init:onprem": "terraform -chdir=terraform/envs/onprem init",
    "tf:plan:onprem": "terraform -chdir=terraform/envs/onprem plan",

    "tf:init:remote": "terraform -chdir=terraform/envs/remote init",
    "tf:plan:remote": "terraform -chdir=terraform/envs/remote plan",

    "tf:check": "npm run tf:fmt && npm run tf:validate:onprem && npm run tf:validate:remote",

    "ansible:vault":         "cd ansible && ansible-playbook playbooks/vault.yml -i inventory/onprem.py",
    "ansible:elk":           "cd ansible && ansible-playbook playbooks/elk.yml -i inventory/onprem.py",
    "ansible:elastic-agent": "cd ansible && ansible-playbook playbooks/elastic-agent.yml -i inventory/onprem.py",
    "ansible:all":           "npm run ansible:vault && npm run ansible:elk && npm run ansible:elastic-agent",

    "deploy": "bash scripts/deploy.sh",
    "destroy": "bash scripts/destroy.sh"
  }
}
