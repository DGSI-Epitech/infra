<!-- TOAST CONTAINER -->
<div class="toast-container" id="toasts"></div>

<script>
  // ── NAVIGATION ──
  function navigate(page) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    const target = document.getElementById('page-' + page);
    if (target) target.classList.add('active');
    document.querySelectorAll('.nav-item').forEach(n => {
      if (n.getAttribute('onclick') && n.getAttribute('onclick').includes("'" + page + "'")) {
        n.classList.add('active');
      }
    });
    if (page === 'calendar') renderCalendar();
  }

  // ── TOAST ──
  function showToast(msg, type = 'info') {
    const c = document.getElementById('toasts');
    const t = document.createElement('div');
    t.className = 'toast' + (type === 'success' ? ' success' : '');
    t.innerHTML = (type === 'success' ? '✓ ' : 'ℹ ') + msg;
    c.appendChild(t);
    setTimeout(() => { t.style.opacity = '0'; t.style.transform = 'translateX(40px)'; t.style.transition = '.3s'; setTimeout(() => t.remove(), 300); }, 2800);
  }

  // ── MODAL ──
  function openModal() {
    document.getElementById('modal').classList.add('open');
  }
  function closeModal() {
    document.getElementById('modal').classList.remove('open');
  }
  function submitTicket() {
    closeModal();
    setTimeout(() => showToast('Ticket #1053 créé avec succès', 'success'), 200);
  }
  document.getElementById('modal').addEventListener('click', e => { if (e.target === e.currentTarget) closeModal(); });

  // ── TOGGLE SWITCH ──
  function toggleSwitch(id) {
    const el = document.getElementById(id);
    const dot = el.querySelector('div');
    const isOn = el.style.background.includes('2563');
    if (isOn) {
      el.style.background = 'var(--gray-200)';
      dot.style.left = '3px'; dot.style.right = '';
    } else {
      el.style.background = 'var(--primary)';
      dot.style.right = '3px'; dot.style.left = '';
    }
  }

  // ── FILTER TICKETS ──
  function filterTickets(btn, filter) {
    btn.closest('.ticket-filters').querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    showToast('Filtrage : ' + btn.textContent, 'info');
  }

  // ── CALENDAR ──
  function renderCalendar() {
    const grid = document.getElementById('cal-grid');
    if (!grid || grid.children.length > 0) return;
    const events = { 17: ['Réunion produit', 'blue'], 19: ['Demo Iris', 'purple'], 21: ['Maintenance SI', 'red'], 24: ['Onboarding', 'green'], 27: ['Séminaire', 'amber'] };
    const firstDay = 0; // June 2025 starts on Sunday → offset 6 in Mon-first
    const daysInMonth = 30;
    for (let i = 0; i < 6; i++) grid.appendChild(Object.assign(document.createElement('div'), {}));
    for (let d = 1; d <= daysInMonth; d++) {
      const cell = document.createElement('div');
      const isToday = d === 17;
      cell.style.cssText = `padding:6px;border-radius:8px;cursor:pointer;min-height:54px;border:1px solid ${isToday?'var(--primary)':'var(--gray-100)'}; background:${isToday?'var(--primary-light)':'transparent'};transition:.15s`;
      cell.onmouseenter = () => { if (!isToday) cell.style.background = 'var(--gray-50)'; };
      cell.onmouseleave = () => { if (!isToday) cell.style.background = 'transparent'; };
      const num = document.createElement('div');
      num.style.cssText = `font-size:12px;font-weight:${isToday?'700':'400'};color:${isToday?'var(--primary)':'var(--gray-700)'};margin-bottom:4px`;
      num.textContent = d;
      cell.appendChild(num);
      if (events[d]) {
        const [label, color] = events[d];
        const ev = document.createElement('div');
        const colors = {blue:'#EFF6FF;color:#2563EB', purple:'#F5F3FF;color:#7C3AED', red:'#FEF2F2;color:#DC2626', green:'#ECFDF5;color:#059669', amber:'#FFFBEB;color:#D97706'};
        ev.style.cssText = `font-size:10px;padding:2px 5px;border-radius:4px;background:${colors[color]};white-space:nowrap;overflow:hidden;text-overflow:ellipsis`;
        ev.textContent = label;
        cell.appendChild(ev);
        cell.onclick = () => showToast(label + ' — ' + d + ' juin', 'info');
      }
      grid.appendChild(cell);
    }
  }
</script>
</body>
