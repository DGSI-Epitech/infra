filebeat.inputs:
  - type: filestream
    id: syslog
    enabled: true
    paths:
      - /var/log/syslog
      - /var/log/auth.log

  - type: filestream
    id: docker-containers
    enabled: true
    paths:
      - /var/lib/docker/containers/*/*.log
    parsers:
      - ndjson:
          message_key: log
          keys_under_root: true
          overwrite_keys: true

output.elasticsearch:
  hosts: ["https://{{ filebeat_elasticsearch_host }}:{{ filebeat_elasticsearch_port }}"]
  username: elastic
  password: "{{ filebeat_elastic_password }}"
  ssl.certificate_authorities: ["{{ filebeat_tls_ca_path }}"]
