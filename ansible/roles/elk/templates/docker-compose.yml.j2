services:
  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:{{ elk_version }}
    container_name: elasticsearch
    environment:
      - cluster.name={{ elk_cluster_name }}
      - node.name=es-node-01
      - discovery.type=single-node
      - ES_JAVA_OPTS=-Xms{{ elk_es_heap_size }} -Xmx{{ elk_es_heap_size }}
      - ELASTIC_PASSWORD={{ elk_elastic_password }}
    volumes:
      - {{ elk_dir }}/elasticsearch/config/elasticsearch.yml:/usr/share/elasticsearch/config/elasticsearch.yml:ro
      - {{ elk_dir }}/elasticsearch/data:/usr/share/elasticsearch/data
    ports:
      - "{{ elk_es_port }}:9200"
      - "{{ elk_es_cluster_port }}:9300"
    networks:
      - elk-net
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -sf -u elastic:{{ elk_elastic_password }} http://localhost:9200/_cluster/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5

  logstash:
    image: docker.elastic.co/logstash/logstash:{{ elk_version }}
    container_name: logstash
    environment:
      - LS_JAVA_OPTS=-Xms{{ elk_ls_heap_size }} -Xmx{{ elk_ls_heap_size }}
      - ELASTICSEARCH_USERNAME=elastic
      - ELASTICSEARCH_PASSWORD={{ elk_elastic_password }}
    volumes:
      - {{ elk_dir }}/logstash/config/logstash.yml:/usr/share/logstash/config/logstash.yml:ro
      - {{ elk_dir }}/logstash/pipeline:/usr/share/logstash/pipeline:ro
    ports:
      - "{{ elk_logstash_beats_port }}:5044"
    networks:
      - elk-net
    depends_on:
      elasticsearch:
        condition: service_healthy
    restart: unless-stopped

  kibana:
    image: docker.elastic.co/kibana/kibana:{{ elk_version }}
    container_name: kibana
    environment:
      - ELASTICSEARCH_HOSTS=http://elasticsearch:9200
      - ELASTICSEARCH_USERNAME=kibana_system
      - ELASTICSEARCH_PASSWORD={{ elk_kibana_system_password }}
      - XPACK_SECURITY_ENCRYPTIONKEY=lab_infra_security_encryption_key_min_32chars
      - XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY=lab_infra_saved_objects_encryption_key_32
      - XPACK_REPORTING_ENCRYPTIONKEY=lab_infra_reporting_encryption_key_32chars
    ports:
      - "{{ elk_kibana_port }}:5601"
    networks:
      - elk-net
    depends_on:
      elasticsearch:
        condition: service_healthy
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:5601/api/status || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 120s

  fleet-server:
    image: docker.elastic.co/beats/elastic-agent:{{ elk_version }}
    container_name: fleet-server
    environment:
      - FLEET_SERVER_ENABLE=1
      - FLEET_SERVER_HOST=0.0.0.0
      - FLEET_SERVER_PORT=8220
      - FLEET_SERVER_ELASTICSEARCH_HOST=http://elasticsearch:{{ elk_es_port }}
      - FLEET_SERVER_SERVICE_TOKEN={{ fleet_server_service_token | default('') }}
      - FLEET_SERVER_ELASTICSEARCH_INSECURE=1
      - FLEET_SERVER_INSECURE_HTTP=1
      - FLEET_URL=http://{{ ansible_host }}:{{ elk_fleet_port }}
      - KIBANA_FLEET_HOST=http://kibana:{{ elk_kibana_port }}
      - KIBANA_FLEET_SETUP=1
      - KIBANA_FLEET_USERNAME=elastic
      - KIBANA_FLEET_PASSWORD={{ elk_elastic_password }}
    ports:
      - "{{ elk_fleet_port }}:8220"
    networks:
      - elk-net
    depends_on:
      elasticsearch:
        condition: service_healthy
      kibana:
        condition: service_healthy
    restart: unless-stopped
    user: root

networks:
  elk-net:
    driver: bridge
