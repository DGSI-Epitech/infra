services:
  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:{{ elk_version }}
    container_name: elasticsearch
    environment:
      - cluster.name={{ elk_cluster_name }}
      - node.name=es-node-01
      - discovery.type=single-node
      - ES_JAVA_OPTS=-Xms{{ elk_es_heap_size }} -Xmx{{ elk_es_heap_size }}
      - ELASTIC_PASSWORD={{ elk_elastic_password }}
    volumes:
      - {{ elk_dir }}/elasticsearch/config/elasticsearch.yml:/usr/share/elasticsearch/config/elasticsearch.yml:ro
      - {{ elk_dir }}/elasticsearch/data:/usr/share/elasticsearch/data
      - {{ elk_tls_host_dir }}:/usr/share/elasticsearch/config/certs:ro
    ports:
      - "{{ elk_es_port }}:9200"
      - "{{ elk_es_cluster_port }}:9300"
    networks:
      - elk-net
    restart: unless-stopped
    mem_limit: {{ elk_es_mem_limit }}
    healthcheck:
      test: ["CMD-SHELL", "curl -sf -u elastic:{{ elk_elastic_password }} https://localhost:9200/_cluster/health --cacert /usr/share/elasticsearch/config/certs/ca.crt || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5

networks:
  elk-net:
    driver: bridge
