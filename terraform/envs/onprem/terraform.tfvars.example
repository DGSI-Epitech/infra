proxmox_endpoint     = "https://<PROXMOX_IP>:8006"
proxmox_node         = "pve"
proxmox_node_address = "<PROXMOX_IP>"
vm_ip_cidr           = "<VM_IP>/24"
vm_gateway           = "<GATEWAY_IP>"
vm_ssh_public_key    = "ssh-ed25519 AAAA..."

# proxmox_api_token must be set via environment variable — never in this file:
# export TF_VAR_proxmox_api_token='root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'
