# --- Proxmox ---
PROXMOX_HOST="X.X.X.X"          # IP publique Proxmox
PROXMOX_USER="root@pam"          # Utilisateur pour auth API
PROXMOX_PASSWORD=""              # Mot de passe root Proxmox (API uniquement)
PROXMOX_NODE="pve"               # Nom du nœud Proxmox
PROXMOX_STORAGE_VM="local"
PROXMOX_STORAGE_ISO="local"

# --- Token API Proxmox (pour Packer et Terraform) ---
PROXMOX_TOKEN_ID="root@pam!packer"   # user@realm!tokenid
PROXMOX_TOKEN=""

# --- VM IDs ---
VM_ID_UBUNTU_TEMPLATE=1000
VM_ID_PFSENSE_TEMPLATE=2000
VM_ID_PFSENSE=2100
VM_ID_SERVICES=1100
VM_ID_OPS=1200

# --- Réseau LAN (derrière pfSense) ---
# Changer ces valeurs suffit pour adapter tout l'infra à un autre réseau.
VM_GATEWAY="172.16.0.254"        # IP LAN de pfSense (gateway des VMs)
VM_LAN_SUBNET="172.16.0.240/28"  # Sous-réseau LAN complet (utilisé par NetBox et pfSense)

# --- IPs statiques des VMs ---
VM_IP_OPS="172.16.0.253/28"      # ops-vm (Vault, ELK) — assignée par DHCP pfSense, vérifier via QEMU agent
VM_IP_SERVICES="172.16.0.241/28" # services-vm (NetBox)
VM_IP_BASTION="10.255.255.249"   # bastion (Teleport, Kibana) — Cloud DMZ vmbr3
VM_IP_WEB="192.168.255.243"      # website — Cloud LAN vmbr4

# --- SSH ---
# Clé publique injectée dans toutes les VMs (Ubuntu via cloud-init, pfSense via config.xml)
SSH_PUBLIC_KEY="ssh-ed25519 AAAA..."
# Chemin vers la clé privée correspondante (doit être sur Proxmox via ssh-copy-id)
SSH_PRIVATE_KEY_FILE="~/.ssh/id_ed25519"

# --- Utilisateur ubuntu des VMs ---
VM_USERNAME="ubuntu"             # Nom de l'utilisateur créé par autoinstall Packer

# --- Ubuntu ISO ---
UBUNTU_ISO_CHECKSUM=""           # SHA256 -> releases.ubuntu.com/22.04/SHA256SUMS

# =============================================================================
# PVE2 — Site Cloud (terraform/envs/remote/)
# =============================================================================

# --- Proxmox PVE2 (même hôte que PVE1 dans la topologie de simulation) ---
PROXMOX_ENDPOINT_REMOTE="https://X.X.X.X:8006"  # Même IP que PROXMOX_HOST
PROXMOX_NODE_ADDRESS_REMOTE="X.X.X.X"           # Même IP que PROXMOX_HOST
PROXMOX_NODE_REMOTE="proxmox-site1"              # Nom du nœud Proxmox
PROXMOX_PASSWORD_REMOTE=""                       # Mot de passe root (identique à PROXMOX_PASSWORD)
PROXMOX_STORAGE_VM_REMOTE="local"                # Storage pour les disques VM sur PVE2
PROXMOX_STORAGE_ISO_REMOTE="local"               # Storage pour cloud-init sur PVE2

# --- Template Ubuntu sur PVE2 ---
VM_ID_UBUNTU_TEMPLATE_REMOTE=1000               # ID du template Ubuntu buildé par Packer

# --- VM IDs PVE2 ---
VM_ID_PFSENSE_TEMPLATE_REMOTE=2000              # Template pfSense sur PVE2
VM_ID_PFSENSE_REMOTE=3200                       # pfSense Cloud (WAN: vmbr2, LAN: vmbr4)
VM_ID_BASTION=240                               # Bastion (Teleport + Kibana) — DMZ vmbr3 10.255.255.249/29
VM_ID_WEBSITE=250                               # Website — LAN Cloud vmbr4 192.168.255.243/28

# --- Bridges Cloud (créés par deploy-remote.sh) ---
PFSENSE_WAN_BRIDGE_REMOTE="vmbr2"              # Transit WAN pfSense Cloud (10.0.0.0/30)
PFSENSE_CLOUD_WAN_TRANSIT="10.0.0.2"           # IP WAN privée de pfSense-Cloud (réseau transit 10.0.0.0/30)
PFSENSE_LAN_BRIDGE_REMOTE="vmbr4"              # Cloud LAN (192.168.255.240/28)
DMZ_BRIDGE_REMOTE="vmbr3"                       # Cloud DMZ (10.255.255.248/29) — bastion
LAN_BRIDGE_REMOTE="vmbr4"                       # Cloud LAN (192.168.255.240/28) — website

# Note : SSH_PUBLIC_KEY et SSH_PRIVATE_KEY_FILE (définis ci-dessus) sont réutilisés pour PVE2

# --- Ansible jump host (ProxyJump via Proxmox — même hôte pour PVE1 et PVE2) ---
PROXMOX_SSH_USER="root"
PFSENSE_USERNAME="admin"
PFSENSE_OP_WAN="X.X.X.X"       # = PROXMOX_HOST (PVE1 jump)
PFSENSE_CLOUD_WAN="X.X.X.X"    # = PROXMOX_HOST (PVE2 jump)