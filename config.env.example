# =============================================================================
# Copier ce fichier en config.env et remplir les valeurs réelles.
# Ne jamais commiter config.env (contient des secrets).
# =============================================================================

# =============================================================================
# PVE1 — Site OP (terraform/envs/onprem/)
# =============================================================================

# --- Proxmox PVE1 ---
# IP publique PVE1
PROXMOX_HOST="X.X.X.X"
PROXMOX_USER="root@pam"
PROXMOX_PASSWORD=""
# Nom du nœud Proxmox sur PVE1
PROXMOX_NODE="pve"
PROXMOX_STORAGE_VM="local"
PROXMOX_STORAGE_ISO="local"

# --- Token API Proxmox PVE1 (pour Packer et Terraform) ---
# format: user@realm!tokenid
PROXMOX_TOKEN_ID="root@pam!packer"
PROXMOX_TOKEN=""

# --- VM IDs PVE1 ---
VM_ID_UBUNTU_TEMPLATE=1000
VM_ID_PFSENSE_TEMPLATE=2000
VM_ID_PFSENSE=3100
VM_ID_
=4200
VM_ID_OPS=4300

# --- Réseau LAN (derrière pfSense) ---
# Changer ces valeurs suffit pour adapter tout l'infra à un autre réseau.
# IP LAN de pfSense (gateway des VMs)
VM_GATEWAY="172.16.0.254"
# Sous-réseau LAN complet (utilisé par NetBox et pfSense)
VM_LAN_SUBNET="172.16.0.240/28"

# --- IPs statiques des VMs PVE1 ---
# Template Ubuntu (temporaire)
VM_IP_TEMPLATE_UBUNTU="172.16.0.100/28"
# services-vm (NetBox)
VM_IP_SERVICES="172.16.0.242/28"
# Même IP sans masque de sous-réseau (utilisé pour tunnels SSH dans les scripts)
SERVICES_IP="172.16.0.242"
# ops-vm (Vault, ELK)
VM_IP_OPS="172.16.0.241/28"

# --- IPs statiques des VMs PVE2 ---
# bastion (Kibana, DMZ Cloud)
VM_IP_BASTION="10.255.255.253"
# web (site, LAN Cloud)
VM_IP_WEB="192.168.255.253"

# --- SSH ---
# Clé publique injectée dans toutes les VMs via cloud-init
SSH_PUBLIC_KEY="ssh-ed25519 AAAA..."
# Chemin vers la clé privée correspondante
SSH_PRIVATE_KEY_FILE="~/.ssh/id_ed25519"

# --- Utilisateurs des VMs ---
# Utilisateur créé par autoinstall Packer
VM_USERNAME="ubuntu"
VM_PASSWORD="ubuntu"
# Hash sha512 du mot de passe (généré avec : mkpasswd --method=sha-512)
VM_PASSWORD_HASH=''
# Utilisateur SSH pour les VMs PVE1 (ops, services)
VM_USERNAME_OP="ubuntu"
# Utilisateur SSH pour les VMs PVE2 (bastion, web)
VM_USERNAME_CLOUD="ubuntu"

# --- Ubuntu ISO ---
# SHA256 -> releases.ubuntu.com/22.04/SHA256SUMS
UBUNTU_ISO_CHECKSUM=""

# --- Ansible / Jumphost ---
# Le jumphost Ansible pour les VMs passe par Proxmox (root@PROXMOX_HOST)
# pfSense OP et Cloud sont joignables via ProxyJump Proxmox → IP WAN interne pfSense
PFSENSE_USERNAME="pfsense"
PFSENSE_PASSWORD="pfsense"
# IP WAN réelle de pfSense OP (bridge vmbr2, réseau 10.0.0.0/30)
PFSENSE_OP_WAN="10.0.0.2"
# IP WAN réelle de pfSense Cloud (bridge CLOUD, réseau 10.0.1.0/30)
PFSENSE_CLOUD_WAN="5.196.50.52"

# --- NetBox ---
NETBOX_API_TOKEN=""

# --- OpenVPN site-to-site (pfSense OP ↔ pfSense Cloud) ---
# Port OpenVPN (pfSense Cloud écoute sur ce port)
VPN_PORT="1194"
# Réseau tunnel entre les deux pfSense (petit /30 dédié au tunnel)
VPN_TUNNEL_NETWORK="10.3.3.0/30"
# Sous-réseau LAN côté Cloud
VM_CLOUD_LAN_SUBNET="192.168.255.240/28"
# Sous-réseau DMZ côté Cloud (bastion)
VM_CLOUD_DMZ_SUBNET="10.255.255.248/29"
# IP LAN de pfSense Cloud (interface LAN = gateway du Cloud LAN)
PFSENSE_CLOUD_LAN_IP="192.168.255.254"
# IP DMZ de pfSense Cloud (interface OPT1 = gateway du réseau DMZ)
PFSENSE_CLOUD_DMZ_IP="10.255.255.254"
# Interface physique DMZ dans pfSense Cloud (3ème carte = vtnet2)
PFSENSE_CLOUD_DMZ_IF="vtnet2"
# Clé partagée OpenVPN (générer avec : openvpn --genkey secret openvpn.key)
VPN_SHARED_KEY=""

# =============================================================================
# PVE2 — Site Cloud (terraform/envs/remote/)
# =============================================================================

# --- Proxmox PVE2 ---
PROXMOX_ENDPOINT_REMOTE="https://<hostname>:8006/"
# IP publique PVE2 (pour SSH bpg provider)
PROXMOX_NODE_ADDRESS_REMOTE="192.99.62.116"
PROXMOX_HOST_REMOTE="192.99.62.116"
# Nom du nœud Proxmox sur PVE2
PROXMOX_NODE_REMOTE="ns525241"
# Mot de passe root PVE2
PROXMOX_PASSWORD_REMOTE=""
# Storage pour les disques VM sur PVE2
PROXMOX_STORAGE_VM_REMOTE="local-lvm"
# Storage pour cloud-init sur PVE2
PROXMOX_STORAGE_ISO_REMOTE="local"

# --- VM IDs PVE2 ---
# ID du template Ubuntu buildé par Packer sur PVE2
VM_ID_UBUNTU_TEMPLATE_REMOTE=1000
VM_ID_PFSENSE_TEMPLATE_REMOTE=102000
# pfSense Cloud
VM_ID_PFSENSE_REMOTE=103100
# Bastion (DMZ Cloud)
VM_ID_BASTION=104200
# Website (LAN Cloud)
VM_ID_WEBSITE=104300

# Note : SSH_PUBLIC_KEY et SSH_PRIVATE_KEY_FILE (définis ci-dessus) sont réutilisés pour PVE2

# --- Bridges Cloud (créés par deploy-remote.sh) ---
PFSENSE_WAN_BRIDGE_REMOTE="vmbr5"              # Transit WAN pfSense Cloud (10.0.1.0/30)
PFSENSE_CLOUD_WAN_TRANSIT="10.0.0.2"           # IP WAN privée de pfSense-Cloud (réseau transit 10.0.0.0/30)
PFSENSE_LAN_BRIDGE_REMOTE="vmbr4"              # Cloud LAN (192.168.255.240/28)
DMZ_BRIDGE_REMOTE="vmbr3"                       # Cloud DMZ (10.255.255.248/29) — bastion
LAN_BRIDGE_REMOTE="vmbr4"                       # Cloud LAN (192.168.255.240/28) — website