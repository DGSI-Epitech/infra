# Proxmox
PROXMOX_HOST="X.X.X.X"
PROXMOX_USER="root@pam"
PROXMOX_PASSWORD=""
PROXMOX_NODE="pve"
PROXMOX_STORAGE_VM="local-lvm"

# VM IDs
VM_ID_UBUNTU_TEMPLATE=9000
VM_ID_PFSENSE_TEMPLATE=9001
VM_ID_PFSENSE=1000
VM_ID_SERVICES=1002
VM_ID_VAULT=1001

# Réseau LAN
VM_IP_SERVICES="172.16.255.242/28"
VM_IP_VAULT="172.16.255.243/28"
VM_GATEWAY="172.16.255.254"

# Clé SSH injectée dans les VMs via cloud-init
SSH_PUBLIC_KEY="ssh-ed25519 AAAA..."

# Mot de passe de l'utilisateur ubuntu sur les VMs
VM_PASSWORD="changeme"

# Mot de passe temporaire utilisé par Packer pendant le build Ubuntu (SSH communicator)
PACKER_BUILD_PASSWORD="packer-build-tmp"
