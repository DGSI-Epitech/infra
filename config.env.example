# =============================================================
# config.env — Source de vérité de l'infrastructure
# Copier ce fichier : cp config.env.example config.env
# Ne jamais committer config.env (gitignored)
#
# IMPORTANT : Les valeurs ci-dessous correspondent aux Proxmox
# de l'école (PVE1 OP + PVE2 Cloud). À adapter si tu déploies
# sur un autre environnement.
# =============================================================

# ============================================================
# PVE1 — OP (on-premise)  |  node: vm3
# Proxmox : ns3050272.ip-51-255-76.eu:8006
# pfSense S1 (VMID 125)  |  DN: op.local
#   WAN vmbr0  → routable 5.196.45.8
#   LAN vmbr1  → 172.16.255.240/28  GW 172.16.255.254
#   DNS via VPN → 192.168.255.254
# ============================================================
PROXMOX_HOST="ns3050272.ip-51-255-76.eu"   # À adapter : IP/hostname de ton Proxmox PVE1
PROXMOX_USER="root@pam"
PROXMOX_PASSWORD=""                         # À remplir : mot de passe root Proxmox
PROXMOX_NODE="vm3"                          # À adapter : nom du nœud dans l'UI Proxmox
PROXMOX_STORAGE_VM="local"
PROXMOX_STORAGE_ISO="local"

# Token API Proxmox (Packer + Terraform)
PROXMOX_TOKEN_ID="root@pam!packer"          # À adapter : user@realm!tokenid
PROXMOX_TOKEN=""                            # À remplir : UUID du token

# VM IDs PVE1
VM_ID_UBUNTU_TEMPLATE=1000
VM_ID_PFSENSE_TEMPLATE=2000
VM_ID_PFSENSE=125                           # VMID du pfSense sur PVE1 (école : 125)
VM_ID_SERVICES=110
VM_ID_VAULT=120

# LAN PVE1 — 172.16.255.240/28 — GW .254, broadcast .255, 13 adresses (.241→.253)
# À adapter si ton réseau LAN est différent
VM_IP_TEMPLATE_UBUNTU="172.16.255.243/28"
VM_IP_SERVICES="172.16.255.241/28"
VM_IP_VAULT="172.16.255.253/28"
VM_GATEWAY="172.16.255.254"                 # IP LAN du pfSense OP (gateway des VMs)
PFSENSE_OP_WAN="5.196.45.8"                 # IP WAN routable du pfSense OP

# pfSense — authentification Ansible
PFSENSE_PASSWORD="pfsense"                  # Mot de passe du compte admin pfSense

# SSH — une seule paire de clés pour toute l'infra (aucun password)
SSH_PUBLIC_KEY="ssh-ed25519 AAAA..."        # cat ~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_FILE="~/.ssh/id_ed25519"    # Doit être copié sur Proxmox via ssh-copy-id

# Utilisateur des VMs Ubuntu
VM_USERNAME="dgsi-cloud"                    # À adapter : nom de l'utilisateur créé par Packer
VM_PASSWORD="01Admin"                       # À adapter : mot de passe (utilisé uniquement pour le hash)
VM_PASSWORD_HASH=''                         # À générer : openssl passwd -6 "TON_PASSWORD"

# Ubuntu ISO
UBUNTU_ISO_CHECKSUM=""                      # SHA256 → releases.ubuntu.com/22.04/SHA256SUMS

# ============================================================
# PVE2 — CLOUD  |  node: vm002
# Proxmox : ns3183326.ip-146-59-253.eu:8006
# pfSense S2 (VMID 106)  |  DN: cloud.local
#   WAN vmbr0   → routable 5.196.50.52
#   DMZ vmbr134 → 10.255.255.248/29   GW 10.255.255.254  (5 adresses)
#   LAN vmbr133 → 192.168.255.240/28  GW 192.168.255.254 (13 adresses)
#   DNS via VPN → 172.16.255.254
# VMs :
#   bastion  vmbr134 enp6s18  10.255.255.253/29
#   web      vmbr133 enp6s18  192.168.255.253/28
# ============================================================
PROXMOX2_HOST="ns3183326.ip-146-59-253.eu" # À adapter : IP/hostname de ton Proxmox PVE2
PROXMOX2_NODE="vm002"                       # À adapter : nom du nœud dans l'UI Proxmox
VM_ID_PFSENSE2=106                          # VMID du pfSense sur PVE2 (école : 106)
VM_IP_BASTION="10.255.255.253/29"           # IP du bastion en DMZ
VM_GATEWAY_DMZ="10.255.255.254"             # Gateway DMZ (pfSense Cloud)
VM_IP_WEB="192.168.255.253/28"              # IP du serveur web en LAN
VM_GATEWAY2="192.168.255.254"               # IP LAN du pfSense Cloud (gateway des VMs)
PFSENSE_CLOUD_WAN="5.196.50.52"             # IP WAN routable du pfSense Cloud
